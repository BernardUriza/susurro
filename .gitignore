# Dependencies
node_modules/
.pnp
.pnp.js

# Production
dist/
build/

# Exception: rnnoise-wasm ships a committed prebuilt WASM artifact (no emscripten
# build runs in the monorepo); keep its dist tracked.
!packages/rnnoise-wasm/dist/
!packages/rnnoise-wasm/dist/**

# Testing
coverage/

# Next.js
.next/
out/

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local env files
.env*.local
.env

# IDE
.vscode/
.idea/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Whisper Models (downloaded at runtime)
public/models/
*.onnx
*.bin

# Test files and temporary
*.py
test_*.html
*.zip
*.msi
whisper-cpp/
backend-examples/
cmake-*/

# Python
__pycache__/
*.pyc
.pytest_cache/
venv/
env/

# WASM files are needed
!public/wasm/rnnoise.wasm

# Susurro Voice Gateway (api/) — force-track despite the repo-wide *.py ignore
!api/
!api/*.py
!api/requirements.txt
!api/Dockerfile
