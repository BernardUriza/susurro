# Susurro Transcription Studio - Environment Variables
# Copy this file to .env.local for development

# ====================
# API Keys (REQUIRED)
# ====================

# Deepgram API Key - Get from https://console.deepgram.com/
VITE_DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Anthropic (Claude) API Key - Get from https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ====================
# Backend URLs
# ====================

# Development - Local backend
VITE_DEEPGRAM_BACKEND_URL=http://localhost:8001

# Susurro Voice Gateway base URL consumed by /docs and /admin pages
VITE_SUSURRO_GATEWAY=https://susurro-gateway.nicecliff-10074f57.eastus.azurecontainerapps.io

# Production - Netlify Functions
# VITE_DEEPGRAM_BACKEND_URL=/.netlify/functions

# ====================
# Feature Flags
# ====================

# Enable Web Speech API (browser-native transcription)
VITE_ENABLE_WEB_SPEECH=true

# Enable Claude refinement
VITE_ENABLE_CLAUDE_REFINEMENT=true

# Enable local Whisper model (for offline use)
VITE_ENABLE_LOCAL_WHISPER=false

# ====================
# Performance Settings
# ====================

# Chunk duration in milliseconds (default: 3000)
VITE_CHUNK_DURATION_MS=3000

# VAD threshold (0-1, default: 0.1)
VITE_VAD_THRESHOLD=0.1

# ====================
# Susurro Voice Gateway (/v1/stt, /v1/tts) — server-side only, NOT VITE_ prefixed
# ====================

# Bootstrap bearer key(s) seeded as project keys. Comma-separated. Real apps get their
# own keys via the claim flow (POST /admin/claims -> /claim); these are the fallback.
SUSURRO_KEYS=generate_a_long_random_key_here

# Admin token for /admin/* (key + claim + usage management). Keep secret.
ADMIN_TOKEN=generate_a_strong_admin_token

# Public demo token shown on /docs (rate-limited, NOT for production apps).
SUSURRO_ONBOARDING_TOKEN=sk-susurro-onboard-xxxx
ONBOARDING_DAILY_LIMIT=50

# Azure Table Storage connection string for per-key metering + claims.
TABLES_CONN=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...

# Surfaced at GET /health for deploy verification (set to the image tag).
GATEWAY_VERSION=dev

# Upstream Azure OpenAI (the gateway holds this; consumers never see it)
AZURE_OPENAI_ENDPOINT=https://susurro-openai.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_WHISPER_DEPLOYMENT=whisper
AZURE_TTS_DEPLOYMENT=tts
AZURE_TTS_MODEL=tts-1
AZURE_TTS_VOICE=onyx
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ====================
# Debugging
# ====================

# Enable debug logs
VITE_DEBUG=false

# Enable Vitest UI for testing
VITE_TEST_UI=false
